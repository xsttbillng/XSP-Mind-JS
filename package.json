{
  "name": "xsp-mind-js",
  "version": "0.3.1",
  "description": "Lightweight JSON-driven flowchart / mindmap display library for embedded docs and marketing pages.",
  "keywords": [
    "mindmap",
    "flowchart",
    "svg",
    "json",
    "lightweight",
    "diagram"
  ],
  "license": "MIT",
  "author": "WUYUANBIAO",
  "homepage": "https://github.com/xsttbillng/XSP-Mind-JS#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsttbillng/XSP-Mind-JS.git"
  },
  "bugs": {
    "url": "https://github.com/xsttbillng/XSP-Mind-JS/issues"
  },
  "type": "module",
  "main": "./dist/xsp-mind.cjs.js",
  "module": "./dist/xsp-mind.esm.js",
  "types": "./dist/xsp-mind.d.ts",
  "style": "./dist/xsp-mind.css",
  "exports": {
    ".": {
      "types": "./dist/xsp-mind.d.ts",
      "import": "./dist/xsp-mind.esm.js",
      "require": "./dist/xsp-mind.cjs.js",
      "default": "./dist/xsp-mind.js"
    },
    "./style.css": "./dist/xsp-mind.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.js",
    "prepublishOnly": "npm run build && npm test",
    "demo": "npx --yes serve . -l 5173",
    "pages:check": "node -e \"console.log('Open http://localhost:5173/ after npm run demo')\""
  },
  "peerDependencies": {
    "@svgdotjs/svg.js": "^3.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "happy-dom": "^17.4.4"
  },
  "engines": {
    "node": ">=18"
  }
}
